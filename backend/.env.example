APP_ENV=development
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
STORAGE_DRIVER=json

# ── API security ──────────────────────────────────────────────────────────────
# Shared secret between the frontend and backend.
# Generate with:  openssl rand -hex 32
# Copy this exact value into frontend/.env.local as NEXT_PUBLIC_API_KEY.
API_KEY=change-me-generate-with-openssl-rand-hex-32

# ── eBay Developer credentials ────────────────────────────────────────────────
# Register at https://developer.ebay.com — create a keyset under your app.
EBAY_CLIENT_ID=your-ebay-client-id-here
EBAY_CLIENT_SECRET=your-ebay-client-secret-here

# !! This is the RuName, NOT the raw URL !!
# 1. Go to developer.ebay.com → App Keys → your keyset → OAuth
# 2. Add redirect URI → actual URL: http://localhost:8080/api/auth/ebay/callback
# 3. eBay generates a RuName string — paste it here.
# Example RuName format: YourName-AppName-SBX-a1b2c3d4e
EBAY_REDIRECT_URI=your-runame-from-ebay-portal-here

EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.fulfillment.readonly https://api.ebay.com/oauth/api_scope/sell.inventory.readonly

# Set to true for sandbox testing, false for production
EBAY_SANDBOX=true
EBAY_SANDBOX_AUTH_URL=https://auth.sandbox.ebay.com/oauth2/authorize
EBAY_SANDBOX_TOKEN_URL=https://api.sandbox.ebay.com/identity/v1/oauth2/token
EBAY_SANDBOX_API_URL=https://api.sandbox.ebay.com
EBAY_PROD_AUTH_URL=https://auth.ebay.com/oauth2/authorize
EBAY_PROD_TOKEN_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_PROD_API_URL=https://api.ebay.com

# ── Token encryption ──────────────────────────────────────────────────────────
# Must be exactly 32 characters. Used for AES-256-CBC encryption of eBay tokens.
# Generate with:  openssl rand -hex 16
ENCRYPTION_KEY=change-me-must-be-exactly-32chars
